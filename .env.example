# Model selection (easy provider swapping)
MODEL_PROVIDER=openai
MODEL_NAME=gpt-5.4
PASS1_MODEL_NAME=gpt-4.1-mini
MODEL_API_KEY=
MODEL_BASE_URL=

# Provider-specific keys (optional if MODEL_API_KEY set)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Corpus paths
NON_ZONING_MARKDOWN=somerville-law-non-zoning.md
ZONING_MARKDOWN=somerville-zoning.md
NON_ZONING_READABLE_HTML=somerville-law-non-zoning.readable.html
ZONING_READABLE_HTML=somerville-zoning.readable.html

# Conversation history
MAX_HISTORY_MESSAGES=8

# Observability logs (JSON line events)
OBSERVABILITY_LOG_LEVEL=INFO
